# Environment variables for Bhubaneswar Change Detection Backend
# Copy this file to .env and fill in the values for local development.
# On Cloud Run, set these via the deployment script or console.

# Google Earth Engine project (reuse from parent project)
GEE_PROJECT_ID=change-detection-494607

# Vercel production URL for CORS (set on Cloud Run)
# Example: https://bhubaneswar-cd.vercel.app
CORS_ORIGIN=

# Note: No GEE_CREDENTIALS_JSON needed.
# Cloud Run uses Application Default Credentials via the attached service account.
# Local dev uses `earthengine authenticate` user credentials.
