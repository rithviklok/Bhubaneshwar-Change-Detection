# Environment variables for Bhubaneswar Change Detection Backend
# Copy this file to .env and fill in the values for local development.
# On Render.com, set these via the dashboard Environment tab.

# Google Earth Engine project (reuse from parent project)
GEE_PROJECT_ID=change-detection-494607

# Base64-encoded service account JSON (required for Render deployment)
# Encode with: base64 -w0 your-service-account.json
# Leave blank for local dev — uses `earthengine authenticate` credentials
GEE_CREDENTIALS_JSON=
